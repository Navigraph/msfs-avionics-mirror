{
  "name": "workingtitle-instruments-uns1",
  "version": "0.1.7",
  "description": "Working Title MSFS UNS-1lw",
  "main": "index.ts",
  "scripts": {
    "build": "npm run build:compile && npm run build:rollup && npm run build:copies",
    "build:compile": "npx tsc",
    "build:rollup": "robocopy html_ui *.css build/html_ui /s & npx rollup -c rollup.config.js",
    "build:copies": "npm run build:copies:extras & npm run build:copies:msfssdk & npm run build:copies:behaviors",
    "build:copies:extras": "robocopy html_ui *.html *.ttf dist/workingtitle-instruments-uns-1lw/html_ui /s",
    "build:copies:msfssdk": "xcopy node_modules\\@microsoft\\msfs-sdk\\msfssdk-iife.js dist\\workingtitle-instruments-uns-1lw\\html_ui\\Pages\\VCockpit\\Instruments\\NavSystems\\WTUns1\\Libraries\\msfssdk.js /Y /-I",
    "build:copies:behaviors": "robocopy ModelBehaviorDefs dist/workingtitle-instruments-uns-1lw/ModelBehaviorDefs /s"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/msfs-avionics-mirror/"
  },
  "author": "Working Title Simulations, LLC",
  "license": "Modified MIT",
  "devDependencies": {
    "@microsoft/msfs-sdk": "0.9.0",
    "@microsoft/msfs-types": "1.14.6",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@types/node": "^18.11.18",
    "rollup": "^2.79.1",
    "rollup-plugin-import-css": "^3.1.0",
    "typescript": "5.3.3"
  }
}
