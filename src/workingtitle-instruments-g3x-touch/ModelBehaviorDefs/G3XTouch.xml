<ModelBehaviors>
	<Include ModelBehaviorFile="Asobo\Generic.xml"/>
	<Include ModelBehaviorFile="Asobo\Common.xml"/>
	<Include ModelBehaviorFile="Asobo\GlassCockpit\AS3X.xml"/>
	<Include ModelBehaviorFile="Asobo\GlassCockpit\AS3X_Touch.xml"/>

	<Template Name="WT_G3XTouch_Knob_Template">
		<Parameters Type="Default">
			<COUNT>36</COUNT>
			<LONG_CLICK_TIME>2</LONG_CLICK_TIME>
			<WWISE_PREFIX>#AS3X#</WWISE_PREFIX>
		</Parameters>

		<Parameters Type="Default">
			<WWISE_EVENT_OUTER_KNOB>#WWISE_PREFIX#_outer_knob</WWISE_EVENT_OUTER_KNOB>
			<WWISE_EVENT_INNER_KNOB>#WWISE_PREFIX#_inner_knob</WWISE_EVENT_INNER_KNOB>
			<WWISE_EVENT_PUSH_1>#WWISE_PREFIX#_knob_push_button_on</WWISE_EVENT_PUSH_1>
			<WWISE_EVENT_PUSH_2>#WWISE_PREFIX#_knob_push_button_off</WWISE_EVENT_PUSH_2>

			<ANIM_NAME_OUTER_KNOB>#AS3X#_Knob_Outer_#KNOB_SUFFIX##SUFFIX_ID#</ANIM_NAME_OUTER_KNOB>
			<ANIM_NAME_INNER_KNOB>#AS3X#_Knob_Inner_#KNOB_SUFFIX##SUFFIX_ID#</ANIM_NAME_INNER_KNOB>
			<ANIM_NAME_INNER_PUSH>#AS3X#_Knob_Inner_#KNOB_SUFFIX#_Push#SUFFIX_ID#</ANIM_NAME_INNER_PUSH>

			<!-- TODO: Temporary generic tooltips. -->
			<TT_DESCRIPTION_ID_OUTER_KNOB>COCKPIT.TOOLTIPSV2.AXNAV_KNOB_SELECTOR_ACTION</TT_DESCRIPTION_ID_OUTER_KNOB>
			<TT_DESCRIPTION_ID_INNER_KNOB>COCKPIT.TOOLTIPSV2.AXNAV_KNOB_SELECTOR_ACTION</TT_DESCRIPTION_ID_INNER_KNOB>
			<TT_DESCRIPTION_ID_INNER_KNOB_PUSH>COCKPIT.TOOLTIPSV3.ACTION.BUTTON_PUSH</TT_DESCRIPTION_ID_INNER_KNOB_PUSH>
		</Parameters>

		<!-- Outer knob -->
		<Component ID="#NODE_ID_OUTER_KNOB#" Node="#NODE_ID_OUTER_KNOB#">
				<Parameters Type="Override">
					<KNOB_ID>Knob_Outer_#KNOB_SUFFIX#</KNOB_ID>
				</Parameters>

				<Parameters Type="Override">
					<TOOLTIP_TITLE>#TOOLTIP_TITLE_OUTER_KNOB#</TOOLTIP_TITLE>
					<TOOLTIP_ENTRY_0>#INPUT_EVENT_ID_SOURCE#_#KNOB_ID#</TOOLTIP_ENTRY_0>
				</Parameters>

				<UseInputEvent ID="#AS3X#">
					<SET_STATE_EXTERNAL>p0 0 &gt; if{ (&gt;H:#HTML_PREFIX#_#KNOB_ID#_INC) } els{ (&gt;H:#HTML_PREFIX#_#KNOB_ID#_DEC) }</SET_STATE_EXTERNAL>
					<TT_DESCRIPTION_ID>#TT_DESCRIPTION_ID_OUTER_KNOB#</TT_DESCRIPTION_ID>
				</UseInputEvent>
				
				<UseTemplate Name="ASOBO_GT_Knob_Infinite">
					<ANIM_NAME>#ANIM_NAME_OUTER_KNOB#</ANIM_NAME>
					<PART_ID>#INPUT_EVENT_ID_SOURCE#_#KNOB_ID#</PART_ID>
					<CLOCKWISE_CODE>1 (&gt;B:#INPUT_EVENT_ID_SOURCE#_#KNOB_ID#_Inc)</CLOCKWISE_CODE>
					<ANTICLOCKWISE_CODE>1 (&gt;B:#INPUT_EVENT_ID_SOURCE#_#KNOB_ID#_Dec)</ANTICLOCKWISE_CODE>
					<WWISE_EVENT>#WWISE_EVENT_OUTER_KNOB#</WWISE_EVENT>
					<THRESHOLD_INPUT>0.0005</THRESHOLD_INPUT>
					<THRESHOLD_MOUSE>0.005</THRESHOLD_MOUSE>
				</UseTemplate>
			</Component>

			<!-- Inner knob -->
			<Component ID="#NODE_ID_INNER_KNOB#" Node="#NODE_ID_INNER_KNOB#">
				<Parameters Type="Override">
					<KNOB_ID>Knob_Inner_#KNOB_SUFFIX#</KNOB_ID>
					<BTN_ID_EXTERNAL>Knob_Inner_Button_#KNOB_SUFFIX#</BTN_ID_EXTERNAL>
				</Parameters>

				<Parameters Type="Override">
					<TOOLTIP_TITLE>#TOOLTIP_TITLE_INNER_KNOB#</TOOLTIP_TITLE>
					<TOOLTIP_ENTRY_0>#INPUT_EVENT_ID_SOURCE#_#KNOB_ID#</TOOLTIP_ENTRY_0>
					<TOOLTIP_ENTRY_1>#INPUT_EVENT_ID_SOURCE#_#BTN_ID_EXTERNAL#</TOOLTIP_ENTRY_1>
				</Parameters>

				<UseInputEvent ID="#AS3X#">
					<TT_INTERACTION>PRIMARY_DOWN+SECONDARY_DOWN</TT_INTERACTION>
					<TT_INTERACTION_LOCKABLE>PRIMARY_DOWN</TT_INTERACTION_LOCKABLE>
					<BTN_ID>#BTN_ID_EXTERNAL#</BTN_ID>
					<!-- Configure event processing -->
					<SET_ARG_COUNT>2</SET_ARG_COUNT><!-- p0: Press/Release, p1:PressDuration, 0 = infinite (if pressing) -->
					<SET_STATE_EXTERNAL>p0 sp0
						l0 0 == if{ (O:_PressTime) 0 &gt; if{ (E:SIMULATION TIME, second) (O:_PressTime) - #LONG_CLICK_TIME# &lt; if{ (&gt;H:#HTML_PREFIX#_#KNOB_ID#_PUSH) 0 (&gt;O:_PressTime) } els{ (&gt;H:#HTML_PREFIX#_#KNOB_ID#_PUSH_LONG) 0 (&gt;O:_PressTime) } } }
						l0 1 == if{ (E:SIMULATION TIME, second) (&gt;O:_PressTime) p1 (&gt;O:_PressForDuration) }
					</SET_STATE_EXTERNAL>
					<ANIM>EXTERNAL</ANIM>
					<BINDING_INC_0>Push</BINDING_INC_0>
					<BINDING_INC_0_PARAM_0>1</BINDING_INC_0_PARAM_0>
					<BINDING_DEC_0>Release</BINDING_DEC_0>
					<BINDING_DEC_0_PARAM_0>0</BINDING_DEC_0_PARAM_0>
					<!-- Configure binding for longpress event -->
					<BINDING_SET_0>Push_Long</BINDING_SET_0>
					<BINDING_SET_0_PARAM_0>1</BINDING_SET_0_PARAM_0>
					<BINDING_SET_0_PARAM_1>#LONG_CLICK_TIME#</BINDING_SET_0_PARAM_1>
					<TT_DESCRIPTION_ID>#TT_DESCRIPTION_ID_INNER_KNOB_PUSH#</TT_DESCRIPTION_ID>
				</UseInputEvent>
				<UseInputEvent ID="#AS3X#">
					<SET_STATE_EXTERNAL>p0 0 &gt; if{ (&gt;H:#HTML_PREFIX#_#KNOB_ID#_INC) } els{ (&gt;H:#HTML_PREFIX#_#KNOB_ID#_DEC) }</SET_STATE_EXTERNAL>
					<TT_DESCRIPTION_ID>#TT_DESCRIPTION_ID_INNER_KNOB#</TT_DESCRIPTION_ID>
				</UseInputEvent>
				<UseTemplate Name="ASOBO_GT_Knob_Infinite_Push_Timed">
					<CURSOR_LEFT>TurnLeftSmall</CURSOR_LEFT>
					<CURSOR_RIGHT>TurnRightSmall</CURSOR_RIGHT>
					<ANIM_NAME_KNOB>#ANIM_NAME_INNER_KNOB#</ANIM_NAME_KNOB>
					<ANIM_NAME_PUSH>#ANIM_NAME_INNER_PUSH#</ANIM_NAME_PUSH>
					<PART_ID>#INPUT_EVENT_ID_SOURCE#_#KNOB_ID#</PART_ID>
					<CLOCKWISE_CODE>1 (&gt;B:#INPUT_EVENT_ID_SOURCE#_#KNOB_ID#_Inc)</CLOCKWISE_CODE>
					<ANTICLOCKWISE_CODE>1 (&gt;B:#INPUT_EVENT_ID_SOURCE#_#KNOB_ID#_Dec)</ANTICLOCKWISE_CODE>
					<LEFT_SINGLE_CODE>(&gt;B:#INPUT_EVENT_ID_SOURCE#_#BTN_ID_EXTERNAL#_Push)</LEFT_SINGLE_CODE>
					<LEFT_LEAVE_CODE>(&gt;B:#INPUT_EVENT_ID_SOURCE#_#BTN_ID_EXTERNAL#_Release)</LEFT_LEAVE_CODE>
					<TIMER_EVENTS_HANDLED_EXTERNALLY>True</TIMER_EVENTS_HANDLED_EXTERNALLY>
					<LOCKABLE_EVENT_SECONDARY>LeftRelease</LOCKABLE_EVENT_SECONDARY>
					<NO_LOCK_EVENT_SECONDARY>RightRelease</NO_LOCK_EVENT_SECONDARY>
					<MOUSEFLAGS_DRAG_IM>RightAll+LeftAll+Wheel+Lock+Unlock</MOUSEFLAGS_DRAG_IM>
					<WWISE_EVENT>#WWISE_EVENT_INNER_KNOB#</WWISE_EVENT>
					<WWISE_EVENT_1>#WWISE_EVENT_PUSH_1#</WWISE_EVENT_1>
					<WWISE_EVENT_2>#WWISE_EVENT_PUSH_2#</WWISE_EVENT_2>
					<THRESHOLD_X_INPUT>0.05</THRESHOLD_X_INPUT>
					<THRESHOLD_X_MOUSE>0.001</THRESHOLD_X_MOUSE>
				</UseTemplate>
				<UseTemplate Name="ASOBO_GT_Emissive_Gauge" />
			</Component>
	</Template>

	<Template Name="WT_G3XTouch_Push_Template">
		<Parameters Type="Default">
			<Condition Check="SUFFIX">
				<NODE_ID>#AS3X#_Push_#SUFFIX##SUFFIX_ID#</NODE_ID>
				<ANIM_NAME>#AS3X#_Push_#SUFFIX##SUFFIX_ID#</ANIM_NAME>
				<PART_ID>#AS3X#_Push_#SUFFIX#</PART_ID>
			</Condition>
			<Condition Check="KEY_ID_OVERRIDE">
				<True>
					<KEY>#KEY_ID_OVERRIDE#_Push</KEY>
				</True>
				<False>
					<Condition Check="SUFFIX">
						<KEY>#SUFFIX#_Push</KEY>
					</Condition>
				</False>
			</Condition>
		</Parameters>

		<UseTemplate Name="ASOBO_AS3X_Push_Button_Template">
			<BTN_ID>#SUFFIX#</BTN_ID>
			<HTML_KEY>#HTML_PREFIX#_#KEY#</HTML_KEY>
		</UseTemplate>
	</Template>

	<Template Name="WT_G3XTouch_Template">
		<Parameters Type="Default">
			<ID>1</ID>
		</Parameters>
		<UseTemplate Name="ASOBO_GT_Helper_Suffix_ID_Appender">
			<TEMPLATE_TO_CALL>WT_G3XTouch_SubTemplate</TEMPLATE_TO_CALL>
		</UseTemplate>
	</Template>

	<Template Name="WT_G3XTouch_SubTemplate">
		<Parameters Type="Default">
			<AS3X>AS3X</AS3X>
			<WWISE_PREFIX>as3x</WWISE_PREFIX>
		</Parameters>

		<Parameters Type="Default">
			<INPUT_EVENT_ID_SOURCE>#AS3X#_Touch#SUFFIX_ID#</INPUT_EVENT_ID_SOURCE>
			<HTML_PREFIX>#AS3X#_Touch#SUFFIX_ID#</HTML_PREFIX>

			<NODE_ID_SCREEN>#AS3X#_Screen#SUFFIX_ID#</NODE_ID_SCREEN>
			<POTENTIOMETER>4</POTENTIOMETER>

			<SCREEN_EMISSIVE_VAR_CODE>(L:WTG3X_Screen_Backlight:#ID#)</SCREEN_EMISSIVE_VAR_CODE>
			<EMISSIVE_MIN>0.05</EMISSIVE_MIN>
			<EMISSIVE_MAX>1</EMISSIVE_MAX>
			<EMISSIVE_GAMMA>2.2</EMISSIVE_GAMMA>

			<NODE_ID_LEFT_OUTER_KNOB>#AS3X#_Knob_Outer_L#SUFFIX_ID#</NODE_ID_LEFT_OUTER_KNOB>
			<NODE_ID_LEFT_INNER_KNOB>#AS3X#_Knob_Inner_L#SUFFIX_ID#</NODE_ID_LEFT_INNER_KNOB>
			<ANIM_NAME_LEFT_OUTER_KNOB>#AS3X#_Knob_Outer_L#SUFFIX_ID#</ANIM_NAME_LEFT_OUTER_KNOB>
			<ANIM_NAME_LEFT_INNER_KNOB>#AS3X#_Knob_Inner_L#SUFFIX_ID#</ANIM_NAME_LEFT_INNER_KNOB>
			<ANIM_NAME_LEFT_INNER_PUSH>#AS3X#_Knob_Inner_L_Push#SUFFIX_ID#</ANIM_NAME_LEFT_INNER_PUSH>

			<NODE_ID_RIGHT_OUTER_KNOB>#AS3X#_Knob_Outer_R#SUFFIX_ID#</NODE_ID_RIGHT_OUTER_KNOB>
			<NODE_ID_RIGHT_INNER_KNOB>#AS3X#_Knob_Inner_R#SUFFIX_ID#</NODE_ID_RIGHT_INNER_KNOB>
			<ANIM_NAME_RIGHT_OUTER_KNOB>#AS3X#_Knob_Outer_R#SUFFIX_ID#</ANIM_NAME_RIGHT_OUTER_KNOB>
			<ANIM_NAME_RIGHT_INNER_KNOB>#AS3X#_Knob_Inner_R#SUFFIX_ID#</ANIM_NAME_RIGHT_INNER_KNOB>
			<ANIM_NAME_RIGHT_INNER_PUSH>#AS3X#_Knob_Inner_R_Push#SUFFIX_ID#</ANIM_NAME_RIGHT_INNER_PUSH>
		</Parameters>

		<Parameters Type="Default">
			<BUTTON_EMISSIVE_MIN>0.05</BUTTON_EMISSIVE_MIN>
			<BUTTON_EMISSIVE_MAX>1</BUTTON_EMISSIVE_MAX>
			<BUTTON_EMISSIVE_GAMMA>2.2</BUTTON_EMISSIVE_GAMMA>
		</Parameters>

		<Parameters Type="Default">
			<SCREEN_EMISSIVE_CODE>#EMISSIVE_MIN# #SCREEN_EMISSIVE_VAR_CODE# #EMISSIVE_GAMMA# pow #EMISSIVE_MAX# #EMISSIVE_MIN# - * +</SCREEN_EMISSIVE_CODE>
			<BUTTON_EMISSIVE_CODE>#BUTTON_EMISSIVE_MIN# #SCREEN_EMISSIVE_VAR_CODE# #BUTTON_EMISSIVE_GAMMA# pow #BUTTON_EMISSIVE_MAX# #BUTTON_EMISSIVE_MIN# - * +</BUTTON_EMISSIVE_CODE>
		
			<Condition Check="CIRCUIT_ID">
				<True>
					<FAILURE>(A:CIRCUIT ON:#CIRCUIT_ID#, Bool)</FAILURE>
				</True>
			</Condition>
		</Parameters>

		<Component ID="#NODE_ID_SCREEN#" Node="#NODE_ID_SCREEN#">
			<UseTemplate Name="ASOBO_GT_Emissive_Gauge">
				<PART_ID>#AS3X#_Touch</PART_ID>
				<EMISSIVE_CODE>#SCREEN_EMISSIVE_CODE#</EMISSIVE_CODE>
			</UseTemplate>
		</Component>

		<UseTemplate Name="WT_G3XTouch_Push_Template">
			<SUFFIX>Nearest</SUFFIX>
			<KEY_ID_OVERRIDE>NRST</KEY_ID_OVERRIDE>
			<EMISSIVE_CODE>#BUTTON_EMISSIVE_CODE#</EMISSIVE_CODE>
			<TT_DESCRIPTION_ID>@TT_Package.AS3X_PUSH_NEAREST_ACTION</TT_DESCRIPTION_ID>
			<TOOLTIP_TITLE>@TT_Package.AS3X_PUSH_NEAREST_TITLE</TOOLTIP_TITLE>
		</UseTemplate>

		<UseTemplate Name="WT_G3XTouch_Push_Template">
			<SUFFIX>DirectTo</SUFFIX>
			<EMISSIVE_CODE>#BUTTON_EMISSIVE_CODE#</EMISSIVE_CODE>
			<TT_DESCRIPTION_ID>@TT_Package.AS3X_PUSH_DIRECTTO_ACTION</TT_DESCRIPTION_ID>
			<TOOLTIP_TITLE>@TT_Package.AS3X_PUSH_DIRECTTO_TITLE</TOOLTIP_TITLE>
		</UseTemplate>

		<UseTemplate Name="WT_G3XTouch_Push_Template">
			<SUFFIX>Menu</SUFFIX>
			<EMISSIVE_CODE>#BUTTON_EMISSIVE_CODE#</EMISSIVE_CODE>
			<TT_DESCRIPTION_ID>@TT_Package.AS3X_PUSH_MENU_ACTION</TT_DESCRIPTION_ID>
			<TOOLTIP_TITLE>@TT_Package.AS3X_PUSH_MENU_TITLE</TOOLTIP_TITLE>
		</UseTemplate>

		<UseTemplate Name="WT_G3XTouch_Push_Template">
			<SUFFIX>Back</SUFFIX>
			<EMISSIVE_CODE>#BUTTON_EMISSIVE_CODE#</EMISSIVE_CODE>
			<TT_DESCRIPTION_ID>@TT_Package.AS3X_PUSH_BACK_ACTION</TT_DESCRIPTION_ID>
			<TOOLTIP_TITLE>@TT_Package.AS3X_PUSH_BACK_TITLE</TOOLTIP_TITLE>
		</UseTemplate>

		<UseTemplate Name="WT_G3XTouch_Knob_Template">
			<KNOB_Suffix>L</KNOB_Suffix>

			<NODE_ID_OUTER_KNOB>#NODE_ID_LEFT_OUTER_KNOB#</NODE_ID_OUTER_KNOB>
			<NODE_ID_INNER_KNOB>#NODE_ID_LEFT_INNER_KNOB#</NODE_ID_INNER_KNOB>

			<ANIM_NAME_OUTER_KNOB>#ANIM_NAME_LEFT_OUTER_KNOB#</ANIM_NAME_OUTER_KNOB>
			<ANIM_NAME_INNER_KNOB>#ANIM_NAME_LEFT_INNER_KNOB#</ANIM_NAME_INNER_KNOB>
			<ANIM_NAME_INNER_PUSH>#ANIM_NAME_LEFT_INNER_PUSH#</ANIM_NAME_INNER_PUSH>

			<TOOLTIP_TITLE_OUTER_KNOB>@TT_Package.AS3X_LEFT_KNOB_OUTER_TITLE</TOOLTIP_TITLE_OUTER_KNOB>
			<TOOLTIP_TITLE_INNER_KNOB>@TT_Package.AS3X_LEFT_KNOB_INNER_TITLE</TOOLTIP_TITLE_INNER_KNOB>

			<EMISSIVE_CODE>#BUTTON_EMISSIVE_CODE#</EMISSIVE_CODE>
		</UseTemplate>

		<UseTemplate Name="WT_G3XTouch_Knob_Template">
			<KNOB_Suffix>R</KNOB_Suffix>

			<NODE_ID_OUTER_KNOB>#NODE_ID_RIGHT_OUTER_KNOB#</NODE_ID_OUTER_KNOB>
			<NODE_ID_INNER_KNOB>#NODE_ID_RIGHT_INNER_KNOB#</NODE_ID_INNER_KNOB>

			<ANIM_NAME_OUTER_KNOB>#ANIM_NAME_RIGHT_OUTER_KNOB#</ANIM_NAME_OUTER_KNOB>
			<ANIM_NAME_INNER_KNOB>#ANIM_NAME_RIGHT_INNER_KNOB#</ANIM_NAME_INNER_KNOB>
			<ANIM_NAME_INNER_PUSH>#ANIM_NAME_RIGHT_INNER_PUSH#</ANIM_NAME_INNER_PUSH>

			<TOOLTIP_TITLE_OUTER_KNOB>@TT_Package.AS3X_RIGHT_KNOB_OUTER_TITLE</TOOLTIP_TITLE_OUTER_KNOB>
			<TOOLTIP_TITLE_INNER_KNOB>@TT_Package.AS3X_RIGHT_KNOB_INNER_TITLE</TOOLTIP_TITLE_INNER_KNOB>
			
			<EMISSIVE_CODE>#BUTTON_EMISSIVE_CODE#</EMISSIVE_CODE>
		</UseTemplate>
	</Template>
</ModelBehaviors>