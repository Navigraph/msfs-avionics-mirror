{
  "name": "workingtitle-instruments-wt21",
  "version": "3.2.13",
  "description": "Working Title MSFS WT21",
  "main": "index.ts",
  "types": "./index.d.ts",
  "scripts": {
    "build": "npm run build:compile && npm run build:rollup && npm run build:copies",
    "build:compile": "npx tspc",
    "build:rollup": "robocopy html_ui *.css build/workingtitle-instruments-wt21-v2/html_ui /s & npx rollup -c rollup.config.mjs",
    "build:copies": "npm run build:copies:extras & npm run build:copies:msfssdk & npm run build:copies:wtlinesdk & npm run build:copies:shared",
    "build:copies:extras": "robocopy html_ui *.svg *.png *.html *.ttf dist/workingtitle-instruments-wt21-v2/html_ui /s",
    "build:copies:msfssdk": "xcopy node_modules\\@microsoft\\msfs-sdk\\msfssdk-iife.js dist\\workingtitle-instruments-wt21-v2\\html_ui\\Pages\\VCockpit\\Instruments\\WT21v2\\Libraries\\msfssdk.js /Y /-I",
    "build:copies:wtlinesdk": "xcopy node_modules\\@microsoft\\msfs-wtlinesdk\\wtlinesdk-iife.js dist\\workingtitle-instruments-wt21-v2\\html_ui\\Pages\\VCockpit\\Instruments\\WT21v2\\Libraries\\wtlinesdk.js /Y /-I",
    "build:copies:shared": "npm run build:copies:shared:js & npm run build:copies:shared:css",
    "build:copies:shared:js": "xcopy node_modules\\@microsoft\\msfs-wt21-shared\\wt21shared.js dist\\workingtitle-instruments-wt21-v2\\html_ui\\Pages\\VCockpit\\Instruments\\WT21v2\\Libraries\\wt21shared.js /Y /-I",
    "build:copies:shared:css": "xcopy node_modules\\@microsoft\\msfs-wt21-shared\\wt21shared.css dist\\workingtitle-instruments-wt21-v2\\html_ui\\Pages\\VCockpit\\Instruments\\WT21v2\\Libraries\\wt21shared.css /Y /-I"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/msfs-avionics-mirror/"
  },
  "author": "Working Title Simulations, LLC",
  "license": "Modified MIT",
  "devDependencies": {
    "@microsoft/msfs-sdk": "2.4.3",
    "@microsoft/msfs-ts-transformer": "^1.0.0",
    "@microsoft/msfs-types": "1.14.6",
    "@microsoft/msfs-wtlinesdk": "0.1.0-dev.7",
    "@microsoft/msfs-wt21-shared": "../shared/dist/msfs-wt21-shared-3.2.13.tgz",
    "@rollup/plugin-image": "^3.0.2",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@types/node": "^18.11.18",
    "rollup": "^4.7.23",
    "rollup-plugin-import-css": "^3.1.0",
    "ts-patch": "^3.3.0",
    "typescript": "5.8.3"
  }
}
