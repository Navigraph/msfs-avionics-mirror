{
  "compilerOptions": {
    "incremental": true,
    "target": "es2017",
    "module": "es2015",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "build/workingtitle-instruments-epic2-v2/html_ui/Pages/VCockpit",
    "declaration": true,
    "declarationMap": true,
    "removeComments": false,
    "moduleResolution": "node",
    "jsxFactory": "FSComponent.buildComponent",
    "jsxFragmentFactory": "FSComponent.Fragment",
    "jsx": "react",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2017",
      "ES2021.WeakRef",
    ],
    "paths": {
      "*": [
        "/*"
      ]
    },
    "plugins": [
      { "transform": "@microsoft/msfs-ts-transformer" },
    ],
  },
  "exclude": [
    "**/node_modules",
    "**/build",
    "**/dist",
  ],
}
