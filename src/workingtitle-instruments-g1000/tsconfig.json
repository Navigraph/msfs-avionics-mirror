{
  "compilerOptions": {
    "incremental": true,
    "target": "es2017",
    "module": "es2015",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "build/workingtitle-instruments-g1000/html_ui/Pages/VCockpit/Instruments/NavSystems/WTG1000",
    "declaration": true,
    "declarationMap": true,
    "removeComments": false,
    "moduleResolution": "node",
    "jsxFactory": "FSComponent.buildComponent",
    "jsxFragmentFactory": "FSComponent.Fragment",
    "jsx": "react",
    "paths": {
      "*": [
        "/*"
      ]
    }
  },
  "exclude": [
    "**/build",
    "**/dist",
    "**/node_modules"
  ]
}